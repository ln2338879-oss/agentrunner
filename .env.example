# ============================================================
# AgentRunner 환경 설정 예시
# ------------------------------------------------------------
# 사용 방법:
# 1. 이 파일을 복사해서 .env 파일을 만듭니다.
#    cp .env.example .env
# 2. 실제 토큰/API 키/채널 ID는 .env에만 입력합니다.
# 3. .env 파일은 절대 GitHub에 올리면 안 됩니다.
# ============================================================

# ============================================================
# Discord 봇 토큰
# ------------------------------------------------------------
# Director는 기본 메인 봇입니다. 최소 실행에는 DIRECTOR_DISCORD_TOKEN이 필요합니다.
# Builder / Factory / Designer를 별도 Discord 봇으로 분리해서 운영할 때만 아래 토큰을 추가합니다.
# ============================================================
DIRECTOR_DISCORD_TOKEN=
BUILDER_DISCORD_TOKEN=
FACTORY_DISCORD_TOKEN=
DESIGNER_DISCORD_TOKEN=

# ============================================================
# Discord slash command 등록
# ------------------------------------------------------------
# DISCORD_CLIENT_ID: Discord Developer Portal의 Application ID입니다.
# DISCORD_GUILD_ID: 테스트 서버 ID입니다. 비워두면 global command 등록 방식으로 사용할 수 있습니다.
# REGISTER_SLASH_COMMANDS=true로 바꾸면 봇 시작 시 slash command 등록을 시도합니다.
# 개발 중에는 GUILD_ID를 넣는 것이 반영이 빠릅니다.
# ============================================================
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
REGISTER_SLASH_COMMANDS=false

# ============================================================
# Discord 채널 ID
# ------------------------------------------------------------
# GAME_DIRECTOR_CHANNEL_ID: 메인 작업 요청을 받을 채널입니다.
# DEV_TASKS_CHANNEL_ID: Builder/개발 작업 알림 채널입니다.
# CONTENT_FACTORY_CHANNEL_ID: Factory/콘텐츠 작업 알림 채널입니다.
# DESIGN_TASKS_CHANNEL_ID: Designer/이미지 작업 알림 채널입니다.
# REVIEW_LOG_CHANNEL_ID: Director 리뷰 결과를 남길 채널입니다.
# BUILD_LOG_CHANNEL_ID: 빌드/검증 로그를 남길 채널입니다.
# 채널 ID는 Discord 개발자 모드에서 채널 우클릭 → ID 복사로 얻을 수 있습니다.
# ============================================================
GAME_DIRECTOR_CHANNEL_ID=
DEV_TASKS_CHANNEL_ID=
CONTENT_FACTORY_CHANNEL_ID=
DESIGN_TASKS_CHANNEL_ID=
REVIEW_LOG_CHANNEL_ID=
BUILD_LOG_CHANNEL_ID=

# ============================================================
# 런타임 경로 설정
# ------------------------------------------------------------
# DATABASE_PATH: SQLite DB 파일 경로입니다. 작업 상태, 리뷰, 아티팩트 기록이 저장됩니다.
# OBSIDIAN_VAULT_PATH: 결과 Markdown 파일을 저장할 Obsidian Vault 폴더입니다.
# PROJECT_ROOT: Builder/Codex가 실제로 작업할 프로젝트 폴더입니다.
# ATTACHMENTS_DIR: Discord 첨부파일을 저장할 폴더입니다.
# DESIGNER_OUTPUT_DIR: Designer가 생성한 이미지 파일을 저장할 폴더입니다.
# MAX_ATTACHMENT_BYTES: 저장할 첨부파일 최대 크기입니다. 기본 10MB입니다.
# ============================================================
DATABASE_PATH=./data/agentrunner.sqlite
OBSIDIAN_VAULT_PATH=./vault/AgentRunnerVault
PROJECT_ROOT=./game-project
ATTACHMENTS_DIR=./data/attachments
DESIGNER_OUTPUT_DIR=./vault/AgentRunnerVault/06_DesignerOutputs
MAX_ATTACHMENT_BYTES=10000000

# ============================================================
# Dashboard 설정
# ------------------------------------------------------------
# DASHBOARD_ENABLED=true로 바꾸면 dashboard 서버를 켤 수 있습니다.
# DASHBOARD_HOST는 기본적으로 127.0.0.1을 권장합니다.
# 현재 dashboard 인증이 없으므로 외부 IP(0.0.0.0)로 공개하지 않는 것을 권장합니다.
# ============================================================
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787

# ============================================================
# Vision adapter 설정
# ------------------------------------------------------------
# 이미지 첨부를 분석해서 프롬프트에 Vision Analysis를 추가하고 싶을 때 사용합니다.
# VISION_COMMAND는 이미지 local_path 목록을 stdin으로 받고, 분석 결과를 stdout으로 출력해야 합니다.
# 사용하지 않으면 비워두면 됩니다.
# 예시:
# VISION_COMMAND=bun scripts/vision-openai.ts
# VISION_COMMAND=bun scripts/vision-gemini.ts
# ============================================================
VISION_COMMAND=
VISION_COMMAND_TIMEOUT_MS=300000

# OpenAI Vision 사용 시 필요합니다.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Gemini Vision / Designer 사용 시 필요합니다.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# ============================================================
# Browser adapter 설정
# ------------------------------------------------------------
# 요청에 URL이 들어있을 때 웹 페이지 내용을 요약해서 프롬프트에 붙이고 싶으면 사용합니다.
# BROWSER_COMMAND는 URL 목록을 stdin으로 받고, 참고 내용을 stdout으로 출력해야 합니다.
# 사용하지 않으면 비워두면 됩니다.
# ============================================================
BROWSER_COMMAND=
BROWSER_COMMAND_TIMEOUT_MS=300000

# ============================================================
# 그룹 / 역할 / 워크플로우 / 스킬 설정 파일
# ------------------------------------------------------------
# GROUPS_CONFIG_PATH: Discord 채널별 workspace/profile/policy 설정입니다.
# ROLES_CONFIG_PATH: director/builder/factory/designer 역할 정의입니다.
# WORKFLOWS_CONFIG_PATH: plan-build-review 같은 workflow 정의입니다.
# SKILLS_DIR: 자동으로 프롬프트에 주입할 skill Markdown 폴더입니다.
# ============================================================
GROUPS_CONFIG_PATH=./configs/groups.yaml
ROLES_CONFIG_PATH=./configs/roles.yaml
WORKFLOWS_CONFIG_PATH=./configs/workflows.yaml
SKILLS_DIR=./skills

# ============================================================
# AI 실행 명령어 / 후보 command 설정
# ------------------------------------------------------------
# ENABLE_AGENT_FAILOVER=true면 command 후보를 순서대로 시도합니다.
# 단, 계정/세션/사용량/인증 문제로 보이는 오류는 자동 전환하지 않고 needs_human으로 멈춥니다.
# CLAUDE_CODE_COMMAND: Director가 사용할 Claude Code 명령어입니다.
# CODEX_COMMAND: Builder가 사용할 Codex 명령어입니다.
# FACTORY_COMMANDS: Factory를 별도 CLI로 실행하고 싶을 때 사용합니다.
# 후보 command는 || 로 구분합니다.
# 예: CLAUDE_CODE_COMMANDS=claude --profile backup||claude --profile fallback
# ============================================================
ENABLE_AGENT_FAILOVER=true
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_COMMANDS=
CODEX_COMMAND=codex
CODEX_COMMANDS=
FACTORY_COMMANDS=
AI_COMMAND_TIMEOUT_MS=600000

# ============================================================
# Ollama / 로컬 LLM 설정
# ------------------------------------------------------------
# Factory가 Ollama OpenAI-compatible endpoint를 사용할 때 필요합니다.
# OLLAMA_BASE_URL: 기본 Ollama endpoint입니다.
# OLLAMA_BASE_URLS: 예비 endpoint 목록입니다. || 로 구분합니다.
# OLLAMA_MODEL: 기본 로컬 모델 이름입니다.
# OLLAMA_MODELS: 예비 모델 목록입니다. || 로 구분합니다.
# 예: OLLAMA_MODEL=gemma3:4b
# 예: OLLAMA_MODELS=qwen2.5:7b||llama3.1:8b
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_BASE_URLS=
OLLAMA_MODEL=gemma
OLLAMA_MODELS=

# ============================================================
# 독립 worker 모드
# ------------------------------------------------------------
# 역할별 worker를 따로 실행할 때 사용합니다.
# systemd의 agentrunner-worker@.service 템플릿에서도 사용됩니다.
# 가능한 값: director, builder, factory, designer
# 비워두면 일반 worker 실행 시 오류가 납니다.
# ============================================================
# AGENTRUNNER_WORKER_ROLE=director
# AGENTRUNNER_WORKER_ROLE=builder
# AGENTRUNNER_WORKER_ROLE=factory
# AGENTRUNNER_WORKER_ROLE=designer
AGENTRUNNER_WORKER_ROLE=
WORKER_POLL_INTERVAL_MS=5000
WORKER_POLL_ONCE=false

# ============================================================
# Builder 검증 명령어
# ------------------------------------------------------------
# Builder가 작업한 뒤 diff/test/build 검증을 실행할 때 사용합니다.
# 비워두면 해당 검증 단계는 건너뜁니다.
# BUILDER_DIFF_COMMAND: 변경 파일 확인용 명령입니다.
# BUILDER_TEST_COMMAND: 테스트 실행 명령입니다. 예: bun test
# BUILDER_BUILD_COMMAND: 빌드 실행 명령입니다. 예: bun run build
# ============================================================
BUILDER_DIFF_COMMAND=git diff --stat && git diff --name-only
BUILDER_TEST_COMMAND=
BUILDER_BUILD_COMMAND=

# ============================================================
# Review safety 설정
# ------------------------------------------------------------
# Reviewer/Arbiter는 원칙적으로 파일을 수정하면 안 됩니다.
# REVIEW_READ_ONLY_GUARD=true면 review/arbitrate 전후의 git 상태를 비교합니다.
# 리뷰 중 파일 변경이 감지되면 READ_ONLY_VIOLATION으로 실패 처리합니다.
# REVIEW_DIFF_COMMAND는 리뷰 프롬프트에 넣을 diff/static check 내용입니다.
# ============================================================
REVIEW_READ_ONLY_GUARD=true
REVIEW_DIFF_COMMAND=git diff --stat && git diff --name-only && git diff --check
REVIEW_CONTEXT_COMMAND_TIMEOUT_MS=120000

# ============================================================
# Strict review gate 설정
# ------------------------------------------------------------
# reviewer가 APPROVED를 내더라도 strict gate가 차단 조건을 찾으면 NEEDS_REVISION으로 내립니다.
# 코드 변경에는 테스트/spec 변경을 요구할 수 있고, 검증 명령 실패를 차단 조건으로 볼 수 있습니다.
# STRICT_REVIEW_COMMANDS는 || 또는 줄바꿈으로 여러 명령을 구분합니다.
# ============================================================
STRICT_REVIEW_ENABLED=true
STRICT_REVIEW_REQUIRE_TESTS=true
STRICT_REVIEW_COMMANDS=
STRICT_REVIEW_COMMAND_TIMEOUT_MS=300000
STRICT_REVIEW_FAIL_ON_VALIDATION_ERROR=true
STRICT_REVIEW_BLOCK_LOCKFILE_CHANGES=false

# ============================================================
# Risk approval gate 설정
# ------------------------------------------------------------
# Builder가 실제 코드 작업을 실행하기 전에 배포, 커밋/푸시, 시크릿, 의존성, CI/자동화 정책 변경 같은
# 고위험 요청을 감지하면 needs_human으로 멈춥니다.
# ============================================================
RISK_APPROVAL_ENABLED=true
RISK_APPROVAL_BLOCK_DESTRUCTIVE_COMMANDS=true
RISK_APPROVAL_REQUIRE_FOR_DEPLOY=true
RISK_APPROVAL_REQUIRE_FOR_SECRETS=true
RISK_APPROVAL_REQUIRE_FOR_DEPENDENCY_CHANGES=true
RISK_APPROVAL_REQUIRE_FOR_CI_CHANGES=true

# ============================================================
# 승인된 작업 후처리 hook
# ------------------------------------------------------------
# Director가 APPROVED를 낸 뒤 자동으로 PR 생성, 브랜치 생성, 커밋 보조 작업을 하고 싶을 때 사용합니다.
# 비워두면 승인 후 별도 hook을 실행하지 않습니다.
# Option 1: 로컬 git branch/commit helper
# APPROVED_TASK_COMMAND=bash scripts/approved-task-git-pr.sh
# Option 2: GitHub Actions workflow_dispatch로 PR 생성 요청
# APPROVED_TASK_COMMAND=bash scripts/trigger-approved-task-workflow.sh
# ============================================================
APPROVED_TASK_COMMAND=
APPROVED_TASK_COMMAND_TIMEOUT_MS=600000
AGENTRUNNER_BASE_BRANCH=main
AGENTRUNNER_PR_DRAFT=true

# ============================================================
# 런타임 정책 / 복구 설정
# ------------------------------------------------------------
# MAX_REVIEW_ROUNDS: NEEDS_REVISION을 몇 번까지 허용할지 정합니다.
# TASK_LEASE_MINUTES: worker가 작업을 잡은 뒤 lock이 유지되는 시간입니다.
# RECOVER_STALE_TASKS_ON_START=true면 시작 시 오래된 running step을 복구합니다.
# STARTUP_RECOVERY_MODE=requeue면 끊긴 running step을 다시 pending으로 돌립니다.
# STARTUP_RECOVERY_MODE=block이면 끊긴 running step을 failed/blocked 처리합니다.
# STALE_TASK_MINUTES: 이 시간 이상 오래된 running 작업을 stale로 봅니다.
# WORKER_HEARTBEAT_INTERVAL_MS: worker/scheduler 생존 기록 주기입니다.
# REQUIRE_USER_APPROVAL_BEFORE_COMMIT: 승인 전 커밋/후처리에 사용자 승인이 필요한지 정합니다.
# ============================================================
MAX_REVIEW_ROUNDS=3
TASK_LEASE_MINUTES=30
RECOVER_STALE_TASKS_ON_START=true
STARTUP_RECOVERY_MODE=requeue
STALE_TASK_MINUTES=120
WORKER_HEARTBEAT_INTERVAL_MS=30000
REQUIRE_USER_APPROVAL_BEFORE_COMMIT=true
