# Discord bot tokens
DIRECTOR_DISCORD_TOKEN=
BUILDER_DISCORD_TOKEN=
FACTORY_DISCORD_TOKEN=

# Discord channel IDs
GAME_DIRECTOR_CHANNEL_ID=
DEV_TASKS_CHANNEL_ID=
CONTENT_FACTORY_CHANNEL_ID=
REVIEW_LOG_CHANNEL_ID=
BUILD_LOG_CHANNEL_ID=

# Runtime paths
DATABASE_PATH=./data/agentrunner.sqlite
OBSIDIAN_VAULT_PATH=./vault/AgentRunnerVault
PROJECT_ROOT=./game-project

# AI execution commands
# The command must read the prompt from stdin and print the result to stdout.
CLAUDE_CODE_COMMAND=claude
CODEX_COMMAND=codex
AI_COMMAND_TIMEOUT_MS=600000

# Local model endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma

# Builder validation commands
# Leave empty to skip a step.
BUILDER_DIFF_COMMAND=git diff --stat && git diff --name-only
BUILDER_TEST_COMMAND=
BUILDER_BUILD_COMMAND=

# Runtime policy
MAX_REVIEW_ROUNDS=3
TASK_LEASE_MINUTES=30
REQUIRE_USER_APPROVAL_BEFORE_COMMIT=true
