# Discord bot tokens
DIRECTOR_DISCORD_TOKEN=
BUILDER_DISCORD_TOKEN=
FACTORY_DISCORD_TOKEN=

# Discord slash command registration
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
REGISTER_SLASH_COMMANDS=false

# Discord channel IDs
GAME_DIRECTOR_CHANNEL_ID=
DEV_TASKS_CHANNEL_ID=
CONTENT_FACTORY_CHANNEL_ID=
REVIEW_LOG_CHANNEL_ID=
BUILD_LOG_CHANNEL_ID=

# Runtime paths
DATABASE_PATH=./data/agentrunner.sqlite
OBSIDIAN_VAULT_PATH=./vault/AgentRunnerVault
PROJECT_ROOT=./game-project
ATTACHMENTS_DIR=./data/attachments
MAX_ATTACHMENT_BYTES=10000000

# Dashboard
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787

# Vision adapter
# The command receives local image paths through stdin and writes analysis to stdout.
# Examples:
# VISION_COMMAND=bun scripts/vision-openai.ts
# VISION_COMMAND=bun scripts/vision-gemini.ts
VISION_COMMAND=
VISION_COMMAND_TIMEOUT_MS=300000
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

# Browser adapter
# The command receives URLs through stdin and writes source-aware notes to stdout.
BROWSER_COMMAND=
BROWSER_COMMAND_TIMEOUT_MS=300000

# Group / skill configuration
GROUPS_CONFIG_PATH=./configs/groups.yaml
SKILLS_DIR=./skills

# AI execution commands and failover candidates
# Use || to define fallback commands/profiles.
ENABLE_AGENT_FAILOVER=true
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_COMMANDS=
CODEX_COMMAND=codex
CODEX_COMMANDS=
FACTORY_COMMANDS=
AI_COMMAND_TIMEOUT_MS=600000

# Local model endpoint and Factory model failover candidates
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_BASE_URLS=
OLLAMA_MODEL=gemma
OLLAMA_MODELS=

# Isolated worker mode
# Used by deploy/systemd/agentrunner-worker@.service.
# AGENTRUNNER_WORKER_ROLE=director
# AGENTRUNNER_WORKER_ROLE=builder
# AGENTRUNNER_WORKER_ROLE=factory
AGENTRUNNER_WORKER_ROLE=

# Builder validation commands
# Leave empty to skip a step.
BUILDER_DIFF_COMMAND=git diff --stat && git diff --name-only
BUILDER_TEST_COMMAND=
BUILDER_BUILD_COMMAND=

# Approved task hook
# Option 1: local branch/commit helper
# APPROVED_TASK_COMMAND=bash scripts/approved-task-git-pr.sh
# Option 2: trigger GitHub Actions workflow_dispatch for PR creation
# APPROVED_TASK_COMMAND=bash scripts/trigger-approved-task-workflow.sh
APPROVED_TASK_COMMAND=
APPROVED_TASK_COMMAND_TIMEOUT_MS=600000
AGENTRUNNER_BASE_BRANCH=main
AGENTRUNNER_PR_DRAFT=true

# Runtime policy
MAX_REVIEW_ROUNDS=3
TASK_LEASE_MINUTES=30
RECOVER_STALE_TASKS_ON_START=true
STALE_TASK_MINUTES=120
REQUIRE_USER_APPROVAL_BEFORE_COMMIT=true
