{
  "name": "agentrunner",
  "version": "0.1.0",
  "description": "Discord multi-agent automation runtime with SQLite state and Obsidian vault integration.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "team": "bun src/team-room/index.ts",
    "dashboard": "bun src/dashboard/index.ts",
    "doctor": "bun src/doctor.ts",
    "proof": "bun src/proof.ts",
    "worker": "bun src/worker/index.ts",
    "scheduler": "bun src/scheduler/index.ts",
    "scheduler:once": "STEP_SCHEDULER_ONCE=true bun src/scheduler/index.ts",
    "setup": "bun src/setup/index.ts",
    "setup:check": "bun src/setup/index.ts --check",
    "setup:local": "bun src/setup/index.ts --local",
    "setup:ubuntu": "bun src/setup/index.ts --ubuntu",
    "setup:systemd": "bun src/setup/index.ts --systemd",
    "setup:vps": "bun src/setup/index.ts --vps",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test --ext .ts",
    "lint:fix": "eslint src test --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check package.json tsconfig.json .prettierrc \".github/workflows/*.{yml,yaml}\"",
    "test": "bun test ./test/**/*.test.ts ./src/**/*.test.ts",
    "quality:check": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "check": "bun run quality:check",
    "build:all": "bun run quality:check && bun run build"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "discord.js": "^14.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
