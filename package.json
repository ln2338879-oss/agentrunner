{
  "name": "agentrunner",
  "version": "0.1.0",
  "description": "Discord 3-bot game-development agent runtime with SQLite state and Obsidian vault integration.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
